{
  "name": "icon-loader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1\" \"tsx watch server/server.ts\"",
    "build:icon-resources": "tsx scripts/build-icon-loader-resources.ts",
    "build": "tsc -p tsconfig.json && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "server": "tsx server/server.ts",
    "vercel:link": "vercel link",
    "vercel:pull:production": "vercel pull --yes --environment=production",
    "vercel:build": "vercel build",
    "vercel:preview": "vercel",
    "vercel:prod": "vercel --prod"
  },
  "dependencies": {
    "@google/genai": "^1.3.0",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "express": "^5.1.0",
    "pixi.js": "^8.9.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "jsdom": "^26.1.0",
    "sharp": "^0.34.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vercel": "^54.10.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
